# Mycelium + CFN Full Stack — Environment Configuration
# Copy to .env and customize before running docker compose

# ── Docker ────────────────────────────────────────────────────────────────────
DOCKER_DEFAULT_PLATFORM=linux/amd64

# ── Mycelium Backend ──────────────────────────────────────────────────────────
MYCELIUM_DB_PASSWORD=password

# ── LLM (CognitiveEngine / coordination) ────────────────────────────────────
# Option 1: Bedrock proxy (Claude Code local proxy)
ANTHROPIC_BASE_URL=http://host.docker.internal:8099/
ANTHROPIC_AUTH_TOKEN=sk-your-litellm-virtual-key-here
# Option 2: Anthropic API key (comment out BASE_URL/AUTH_TOKEN above)
# ANTHROPIC_API_KEY=sk-ant-...
COORDINATION_LLM_MODEL=bedrock/global.anthropic.claude-sonnet-4-6

# ── CFN Management Plane ──────────────────────────────────────────────────────
CFN_DB=cfn_mgmt
CFN_DB_USER=postgres
CFN_DB_PASSWORD=password
ADMIN_USER_PASSWORD=admin
CFN_DEV_MODE=false
CFN_NAME=default-cfn
HEARTBEAT_INTERVAL_SECONDS=10
MCP_ENABLED=false
MCP_PORT=9002

# ── CFN Knowledge Graph (AgensGraph) ─────────────────────────────────────────
AGENSGRAPH_DB=ioc-graph-db
AGENSGRAPH_USER=postgres
AGENSGRAPH_PASSWORD=agensgraph

# ── CFN Management UI ─────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:9001
NEXTAUTH_SECRET=mycelium-dev-secret-change-in-production
