# Mycelium default environment — copied to ~/.mycelium/.env on install
# LLM vars are filled in by the installer prompts.

# Postgres (mycelium-db)
MYCELIUM_DB_PASSWORD=password

# IoC CFN stack (cfn profile only)
# CFN_MGMT_URL is set automatically when cfn profile is active
# Set to http://ioc-cfn-mgmt-plane-svc:9000 when running with --profile cfn
CFN_MGMT_URL=
CFN_DB=cfn_mgmt
CFN_DB_USER=postgres
CFN_DB_PASSWORD=password
ADMIN_USER_PASSWORD=admin
CFN_DEV_MODE=false

# Anthropic / LLM (filled by installer)
MYCELIUM_ANTHROPIC_BASE_URL=
MYCELIUM_ANTHROPIC_AUTH_TOKEN=
MYCELIUM_ANTHROPIC_API_KEY=
COORDINATION_LLM_MODEL=claude-sonnet-4-6
