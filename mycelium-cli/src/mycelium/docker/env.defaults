# Mycelium default environment — copied to ~/.mycelium/.env on install
# LLM vars are filled in by the installer prompts.

# Postgres (shared by mycelium and cfn profile)
MYCELIUM_DB_PASSWORD=password

# IoC CFN stack (cfn profile only)
# CFN_MGMT_URL and WORKSPACE_ID are set automatically when cfn profile is active
CFN_MGMT_URL=
CFN_DB=cfn_mgmt
ADMIN_USER_PASSWORD=admin
CFN_DEV_MODE=false

# CFN Python node svc (cfn profile only)
# Path to ioc-cognition-fabric-node-svc repo, relative to compose.yml
COGNITION_FABRIC_SVC_PATH=../../ioc-cognition-fabric-node-svc
# Set automatically when cfn profile is active (http://ioc-cognition-fabric-node-svc:9002)
COGNITION_FABRIC_NODE_URL=
WORKSPACE_ID=

# Data directory — volume-mounted into the backend container so CLI and
# backend share the same .mycelium/ filesystem (rooms, notebooks, config).
MYCELIUM_DATA_DIR=~/.mycelium

# LLM (filled by installer)
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=
