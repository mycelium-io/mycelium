# Mycelium environment defaults — auto-generated by 'mycelium config apply'
# Edit values via: mycelium config set llm.model <value>
# Do not edit this file manually.

# Postgres (shared by mycelium and cfn profile)
MYCELIUM_DB_PASSWORD=password

# IoC CFN stack (cfn profile only)
# CFN_MGMT_URL is set automatically when cfn profile is active
CFN_MGMT_URL=
CFN_DB=cfn_mgmt
ADMIN_USER_PASSWORD=admin
CFN_DEV_MODE=false

# LLM (filled by installer)
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=
