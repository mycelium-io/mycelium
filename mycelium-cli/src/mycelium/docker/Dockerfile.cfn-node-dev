# SPDX-License-Identifier: Apache-2.0
# Development override: build ioc-cognition-fabric-node-svc with a local
# cognition-engine wheel (e.g. from the litellm branch) instead of pulling
# from Artifactory.
#
# Usage (from mycelium repo root):
#   cp /path/to/cognition_engine-*.whl .docker-dev/cognition_engine.whl
#   docker build \
#     -f mycelium-cli/src/mycelium/docker/Dockerfile.cfn-node-dev \
#     -t ghcr.io/cisco-eti/ioc-cognition-fabric-node-svc:dev \
#     .docker-dev/

FROM ghcr.io/cisco-eti/ioc-cognition-fabric-node-svc:latest
USER root
COPY cognition_engine.whl /tmp/cognition_engine.whl
RUN /opt/venv/bin/pip install --force-reinstall --no-deps /tmp/cognition_engine.whl
USER app
