{
  "name": "mycelium-cli",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build":    "uv sync --frozen",
    "dev":      "echo \"CLI has no dev server\"",
    "lint":     "uv run ruff check .",
    "lint:fix": "uv run ruff check . --fix",
    "test":     "uv run pytest",
    "clean":    "rm -rf __pycache__ .pytest_cache"
  }
}
